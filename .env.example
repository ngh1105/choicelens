# Get one at https://cloud.reown.com (formerly WalletConnect Cloud)
# Leave unset to disable wallet connect; the UI falls back to a disabled button.
NEXT_PUBLIC_WC_PROJECT_ID=

# Phase 3A data foundation. Local dev defaults to SQLite under prisma/.
# Swap for a managed Postgres URL (and the schema provider) when promoting beyond dev.
DATABASE_URL="file:./dev.db"

# Phase 3B GenLayer integration (server side).
# GENLAYER_NETWORK: "mock" | "studionet". Default is mock — no network is hit.
GENLAYER_NETWORK=mock
GENLAYER_CONTRACT_ADDRESS=
GENLAYER_SERVICE_PRIVATE_KEY=
GENLAYER_RPC_URL=

# Studionet operator block (uncomment + fill in production / staging).
# The contract address below is the live Phase 3B Studionet deploy.
# GENLAYER_SERVICE_PRIVATE_KEY MUST come from a secret manager — never commit a real key.
# GENLAYER_NETWORK=studionet
# GENLAYER_RPC_URL=https://studio.genlayer.com/api
# GENLAYER_CONTRACT_ADDRESS=0x8c050968E9D923C7C2612F58aE965723964Ea770
# GENLAYER_SERVICE_PRIVATE_KEY=replace_with_funded_service_key_never_commit_real_value

# Phase 3B GenLayer integration (browser, wallet path).
# Mirror of the server values, exposed to the bundle. Leaving these unset
# disables the wallet path; the UI hides the wallet sign action.
NEXT_PUBLIC_GENLAYER_NETWORK=mock
NEXT_PUBLIC_GENLAYER_CONTRACT_ADDRESS=
NEXT_PUBLIC_GENLAYER_CHAIN_ID=
NEXT_PUBLIC_GENLAYER_RPC_URL=
