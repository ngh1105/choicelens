# Get one at https://cloud.reown.com (formerly WalletConnect Cloud)
# Leave unset to disable wallet connect; the UI falls back to a disabled button.
NEXT_PUBLIC_WC_PROJECT_ID=

# Phase 3A+ data foundation. Prisma is configured for Postgres.
# Use a local or managed Postgres URL for development, staging, and production.
DATABASE_URL="postgresql://user:password@localhost:5432/choicelens"

# App origin used for Stripe redirects and SIWE domain checks.
APP_BASE_URL=http://localhost:3000

# Wallet-paid identity session. Generate a long random value per environment.
WALLET_SESSION_SECRET=replace_with_long_random_secret

# Optional separate HMAC secret for wallet recovery tokens. If unset, recovery
# tokens fall back to WALLET_SESSION_SECRET with recovery-specific domain
# separation. Use a distinct long random value in production when possible.
WALLET_RECOVERY_TOKEN_SECRET=

# Wallet recovery via email OTP. Leave RESEND_API_KEY unset to disable email
# delivery; the flow still issues OTPs (see server logs in dev) but no email
# leaves the box.
RESEND_API_KEY=
RESEND_FROM="ChoiceLens <recovery@choicelens.app>"

# V2 monetization beta. Leave unset to disable real checkout/portal flows.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLUS_PRICE_ID=

# Toggle the V2 monetization beta. Default: enabled.
# Set to "false" (or "0", "off") to run the product as full-Free during the beta:
# every user is treated as effective-Plus for usage caps, /api/billing/* returns
# 503 billing_disabled, and /pricing + /account hide the paid surfaces.
BILLING_ENABLED=true

# Phase 3B GenLayer integration (server side).
# GENLAYER_NETWORK: "mock" | "studionet". Default is mock — no network is hit.
GENLAYER_NETWORK=mock
GENLAYER_CONTRACT_ADDRESS=
GENLAYER_SERVICE_PRIVATE_KEY=
GENLAYER_RPC_URL=

# Studionet operator block (uncomment + fill in production / staging).
# The contract address below is the live Phase 3B Studionet deploy.
# GENLAYER_SERVICE_PRIVATE_KEY MUST come from a secret manager — never commit a real key.
# GENLAYER_NETWORK=studionet
# GENLAYER_RPC_URL=https://studio.genlayer.com/api
# GENLAYER_CONTRACT_ADDRESS=0xD7E2910DBbCb701992591b4285985a3Ad0e0A418
# GENLAYER_SERVICE_PRIVATE_KEY=replace_with_funded_service_key_never_commit_real_value

# Phase 3B GenLayer integration (browser, wallet path).
# Mirror of the server values, exposed to the bundle. Leaving these unset
# disables the wallet path; the UI hides the wallet sign action.
NEXT_PUBLIC_GENLAYER_NETWORK=mock
NEXT_PUBLIC_GENLAYER_CONTRACT_ADDRESS=
NEXT_PUBLIC_GENLAYER_CHAIN_ID=
NEXT_PUBLIC_GENLAYER_RPC_URL=
