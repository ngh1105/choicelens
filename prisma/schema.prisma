// Postgres for both dev and prod. Neon-managed in production.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(cuid())
  handle                   String    @unique
  plan                     String    @default("free")
  primaryWalletAddress     String?   @unique
  walletLinkedAt           DateTime?
  recoveryEmail            String?   @unique
  recoveryEmailVerifiedAt  DateTime?
  recoveryLockedUntil      DateTime?
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  stripePriceId            String?
  stripeSubscriptionStatus String?
  stripeCurrentPeriodEnd   DateTime?
  createdAt                DateTime  @default(now())

  comparisons Comparison[]
  watchlist   WatchlistEntry[]
  walletLinkRequests WalletLinkRequest[]
  emailOtps          EmailOtp[]
  feedback           ComparisonFeedback[]
}

model Comparison {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  // Serialized JSON of ComparisonInput and ComparisonResult.
  // SQLite has no native JSON type; we store strings and parse in the store layer.
  input     String
  result    String

  watchlist WatchlistEntry[]
  receipt   Receipt?
  feedback  ComparisonFeedback[]

  @@index([userId, createdAt])
}

model WatchlistEntry {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  comparisonId String
  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  optionId     String
  name         String
  score        Float
  payloadHash  String
  addedAt      DateTime   @default(now())

  @@unique([comparisonId, payloadHash])
  @@index([userId, addedAt])
}

model ComparisonFeedback {
  id           String     @id @default(cuid())
  comparisonId String
  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  helpful      Boolean
  createdAt    DateTime   @default(now())

  @@index([comparisonId, createdAt])
  @@index([userId, createdAt])
}

model Receipt {
  id              String     @id
  comparisonId    String     @unique
  comparison      Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  payloadHash     String
  status          String
  network         String
  submitterKind   String     // "service" | "user" | "mock"
  creatorAddress  String?
  contractAddress String?
  transactionHash String?
  executionResult String?    // "ok" | "error" | raw genlayer name
  errorCode       String?    // GenLayerError code if status=failed
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model WalletLinkRequest {
  id                     String    @id @default(cuid())
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedWalletAddress String
  challengeNonce         String
  status                 String
  expiresAt              DateTime
  createdAt              DateTime  @default(now())
  confirmedAt            DateTime?

  @@index([userId, status, expiresAt])
  @@index([requestedWalletAddress])
}

model EmailOtp {
  id                  String    @id @default(cuid())
  email               String
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose             String
  codeHash            String
  attempts            Int       @default(0)
  expiresAt           DateTime
  consumedAt          DateTime?
  recoveryConfirmedAt DateTime?
  createdAt           DateTime  @default(now())

  @@index([email, purpose, createdAt])
  @@index([userId, purpose, createdAt])
}

model StripeWebhookEvent {
  id           String    @id
  type         String
  status       String
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?
  errorMessage String?
}
